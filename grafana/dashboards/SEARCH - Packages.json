            "keepTime": false,
            "replace": false,
            "source": "Line"
          }
        },
        {
          "id": "filterByValue",
          "options": {
            "filters": [
              {
                "config": {
                  "id": "regex",
                  "options": {
                    "value": "^(?!.*\\..*)(?!.*sandbox.*).*$"
                  }
                },
                "fieldName": "orgIdentifier"
              }
            ],
            "match": "all",
            "type": "include"
          }
        },
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "All active licenses": {
                "aggregations": [
                  "last"
                ],
                "operation": "aggregate"
              },
              "Salesforce Org Identifier": {
                "aggregations": [],
                "operation": "groupby"
              },
              "orgIdentifier": {
                "aggregations": [],
                "operation": "groupby"
              }
            }
          }
        },
