# =============================================================
# Salesforce CI/CD — Git attributes
# Normalize line endings to LF on all platforms.
# =============================================================

# All text files: store as LF
* text=auto eol=lf

# Binary files — no diff, no merge
*.png                       binary
*.jpg                       binary
*.jpeg                      binary
*.gif                       binary
*.ico                       binary
*.svg                       binary
*.zip                       binary
*.jar                       binary
*.pdf                       binary
*.xlsx                      binary
*.docx                      binary
